# ═══════════════════════════════════════════════════════════
# Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# Docker Compose uses DB_* vars for the PostgreSQL container.

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/breakthebox_dev
DB_NAME=breakthebox_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# ─── Auth0 OAuth ───
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ─── Optional: Google OAuth ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── AI (Anthropic Claude) ───
ANTHROPIC_API_KEY=

# ─── App ───
PUBLIC_APP_URL=http://localhost:5173
UPLOAD_DIR=./uploads

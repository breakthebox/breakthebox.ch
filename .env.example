# ═══════════════════════════════════════════════════════════
# Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# Docker Compose uses DB_* vars for the PostgreSQL container.

# ─── Database ───
# DB_PORT ist der Host-Port (Container bleibt intern 5432). Standard 5433,
# um Konflikte mit anderen lokalen Postgres-Instanzen (Port 5432) zu vermeiden.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/breakthebox_dev
DB_NAME=breakthebox_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5433

# ─── Auth0 OAuth ───
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ─── Optional: Google OAuth ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── AI (Anthropic Claude) ───
ANTHROPIC_API_KEY=

# ─── Miss Bizzy Chat (n8n Webhook) ───
# URL des n8n-Webhooks, der die Chat-Anfragen beantwortet (serverseitig, nie im Browser).
# Ist die URL leer, läuft der Chat im «Offline»-Modus (freundlicher Hinweis statt Antwort).
CHAT_WEBHOOK_URL=
# Gemeinsames Secret; wird als Header `X-BTB-Secret` mitgeschickt. In n8n prüfen.
CHAT_WEBHOOK_SECRET=

# ─── App ───
# Dev-Server läuft auf Port 5174 (siehe vite.config.ts).
PUBLIC_APP_URL=http://localhost:5174
UPLOAD_DIR=./uploads

# ─── Web-Analyse (Umami Cloud, cookielos) ───
# Website-ID (UUID) aus dem Umami-Konto (Settings → Websites). Leer lassen = Analyse aus.
# Nur setzen, wenn das Umami-Konto existiert und die Datenschutzerklärung entsprechend live ist.
PUBLIC_UMAMI_WEBSITE_ID=
# Optional: Script-URL überschreiben (nur für Self-Hosting nötig).
# Standard (Umami Cloud): https://cloud.umami.is/script.js
PUBLIC_UMAMI_SRC=

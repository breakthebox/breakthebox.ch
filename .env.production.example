# ═══════════════════════════════════════════════════════════
# Production Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env.production on the server and fill in values.

# ─── Database ───
DB_NAME=breakthebox
DB_USER=breakthebox
DB_PASSWORD=          # Use a strong, random password!

# ─── Auth0 OAuth ───
AUTH0_DOMAIN=breakthebox.eu.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ─── AI (Anthropic Claude) ───
ANTHROPIC_API_KEY=

# ─── App ───
PUBLIC_APP_URL=https://breakthebox.ch
UPLOAD_DIR=/app/uploads
